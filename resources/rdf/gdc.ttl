  <http://syn.org/isCDEVersion> 1.0E0;
  <http://syn.org/isCDE> 8037927;
  <http://syn.org/hasCDEOrigin> "caDSR";
  <http://syn.org/acceptableValues> "[\"DMEM\",\"DMEM+Serum\",\"RPMI+Serum\",\"PBS+Serum\",\"None\"]";
  <http://syn.org/requirement> "required";
  <http://purl.org/dc/terms/description> "A material that infiltrates and supports a specimen and preserves its shape and structure for sectioning and microscopy.";
  <http://syn.org/source> "\"";
  <http://syn.org/isKey> false .

<http://syn.org/gdc/MultiplexMicroscopy/staining_method> <http://syn.org/node> <http://syn.org/gdc/MultiplexMicroscopy>;
  <http://www.w3.org/2000/01/rdf-schema#label> "staining_method";
