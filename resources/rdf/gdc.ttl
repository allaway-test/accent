  <http://syn.org/isKey> false .

<http://syn.org/gdc/MultiplexMicroscopy/tissue_fixative> <http://syn.org/node> <http://syn.org/gdc/MultiplexMicroscopy>;
  <http://www.w3.org/2000/01/rdf-schema#label> "tissue_fixative";
