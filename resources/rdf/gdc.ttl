  <http://syn.org/requirement> "required";
  <http://purl.org/dc/terms/description> "A compound that preserves tissues and cells for microscopic study.";
  <http://syn.org/source> "\"";
  <http://syn.org/isKey> false .

<http://syn.org/gdc/MultiplexMicroscopy/embedding_medium> <http://syn.org/node> <http://syn.org/gdc/MultiplexMicroscopy>;
  <http://www.w3.org/2000/01/rdf-schema#label> "embedding_medium";
  <http://syn.org/datatype> "string";
