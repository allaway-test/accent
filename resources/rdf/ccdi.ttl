  <http://purl.org/dc/terms/description> "Numeric value used to describe the lower limit of the normal range used to describe a healthy individual at the institution where the test was completed.";
  <http://syn.org/node> <http://syn.org/ccdi/molecular_test>;
  <http://syn.org/type> "integer";
  <http://syn.org/isCDE> 6142571 .

