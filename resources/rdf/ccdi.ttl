  <http://syn.org/type> "string";
  <http://syn.org/requiredBy> <http://syn.org/ccdi/molecular_test>;
  <http://syn.org/isKey> true;
  <http://syn.org/isCDE> 14589997 .

<http://syn.org/ccdi/molecular_test/age_at_molecular_test> <http://www.w3.org/2000/01/rdf-schema#label>
