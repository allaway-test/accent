  <http://purl.org/dc/terms/description> "A string of characters representing either a fixed point number or a floating point number capturing the nominal slice thickness relative to the patient-based coordinate system expressed in number of millimeters.";
  <http://syn.org/node> <http://syn.org/ccdi/radiology_file>;
  <http://syn.org/type> "string";
  <http://syn.org/isCDE> 3113185 .

